{
  "name": "kotonia-agent",
  "displayName": "Kotonia Agent",
  "description": "%extension.description%",
  "version": "0.0.20",
  "publisher": "shinjishimizu",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhener562/kotonia-vscode.git"
  },
  "homepage": "https://github.com/zhener562/kotonia-vscode#readme",
  "bugs": {
    "url": "https://github.com/zhener562/kotonia-vscode/issues"
  },
  "keywords": [
    "agent",
    "ai",
    "assistant",
    "rust",
    "cli"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onView:kotonia.sessions"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kotonia",
          "title": "Kotonia",
          "icon": "media/flame.svg"
        }
      ]
    },
    "views": {
      "kotonia": [
        {
          "id": "kotonia.sessions",
          "name": "%view.sessions.name%"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "kotonia.newChat",
          "when": "view == kotonia.sessions",
          "group": "navigation@1"
        },
        {
          "command": "kotonia.refreshSessions",
          "when": "view == kotonia.sessions",
          "group": "navigation@2"
        },
        {
          "command": "kotonia.selectModel",
          "when": "view == kotonia.sessions",
          "group": "navigation@3"
        },
        {
          "command": "kotonia.selectAvatar",
          "when": "view == kotonia.sessions",
          "group": "navigation@4"
        },
        {
          "command": "kotonia.login",
          "when": "view == kotonia.sessions && !kotonia.loggedIn",
          "group": "navigation@9"
        },
        {
          "command": "kotonia.logout",
          "when": "view == kotonia.sessions && kotonia.loggedIn",
          "group": "navigation@9"
        },
        {
          "command": "kotonia.showAvatar",
          "when": "view == kotonia.sessions",
          "group": "9_more@1"
        },
        {
          "command": "kotonia.toggleAvatar",
          "when": "view == kotonia.sessions",
          "group": "9_more@2"
        },
        {
          "command": "kotonia.reviewChanges",
          "when": "view == kotonia.sessions",
          "group": "9_more@3"
        },
        {
          "command": "kotonia.applyChanges",
          "when": "view == kotonia.sessions",
          "group": "9_more@4"
        },
        {
          "command": "kotonia.setDeepSeekApiKey",
          "when": "view == kotonia.sessions",
          "group": "9_more@5"
        },
        {
          "command": "kotonia.help",
          "when": "view == kotonia.sessions",
          "group": "9_more@9"
        }
      ]
    },
    "commands": [
      {
        "command": "kotonia.start",
        "title": "%cmd.start.title%",
        "category": "Kotonia"
      },
      {
        "command": "kotonia.newChat",
        "title": "%cmd.newChat.title%",
        "category": "Kotonia",
        "icon": "$(add)"
      },
      {
        "command": "kotonia.refreshSessions",
        "title": "%cmd.refreshSessions.title%",
        "category": "Kotonia",
        "icon": "$(refresh)"
      },
      {
        "command": "kotonia.openSession",
        "title": "%cmd.openSession.title%",
        "category": "Kotonia"
      },
      {
        "command": "kotonia.login",
        "title": "%cmd.login.title%",
        "category": "Kotonia",
        "icon": "$(sign-in)"
      },
      {
        "command": "kotonia.logout",
        "title": "%cmd.logout.title%",
        "category": "Kotonia",
        "icon": "$(sign-out)"
      },
      {
        "command": "kotonia.selectModel",
        "title": "%cmd.selectModel.title%",
        "category": "Kotonia",
        "icon": "$(chip)"
      },
      {
        "command": "kotonia.toggleAvatar",
        "title": "%cmd.toggleAvatar.title%",
        "category": "Kotonia"
      },
      {
        "command": "kotonia.selectAvatar",
        "title": "%cmd.selectAvatar.title%",
        "category": "Kotonia",
        "icon": "$(account)"
      },
      {
        "command": "kotonia.showAvatar",
        "title": "%cmd.showAvatar.title%",
        "category": "Kotonia"
      },
      {
        "command": "kotonia.help",
        "title": "%cmd.help.title%",
        "category": "Kotonia",
        "icon": "$(question)"
      },
      {
        "command": "kotonia.cancel",
        "title": "%cmd.cancel.title%",
        "category": "Kotonia"
      },
      {
        "command": "kotonia.reviewChanges",
        "title": "%cmd.reviewChanges.title%",
        "category": "Kotonia"
      },
      {
        "command": "kotonia.applyChanges",
        "title": "%cmd.applyChanges.title%",
        "category": "Kotonia"
      },
      {
        "command": "kotonia.setKotoniaApiKey",
        "title": "%cmd.setKotoniaApiKey.title%",
        "category": "Kotonia"
      },
      {
        "command": "kotonia.setDeepSeekApiKey",
        "title": "%cmd.setDeepSeekApiKey.title%",
        "category": "Kotonia"
      }
    ],
    "configuration": {
      "title": "Kotonia Agent",
      "properties": {
        "kotonia.enginePath": {
          "type": "string",
          "default": "kotonia-cli",
          "markdownDescription": "Path to the `kotonia-cli` engine binary. Resolved on the extension host (i.e. the remote/WSL host when connected). The default uses the bundled helper binary when present, then falls back to PATH. Point at a debug build like `${workspaceFolder}/target/debug/kotonia-cli` to override it."
        },
        "kotonia.model": {
          "type": "string",
          "default": "kotonia-gemma4-26b",
          "markdownDescription": "Model id passed to the engine. Hosted (GPU-free, needs `KOTONIA_API_KEY`): `kotonia-gemma4-26b`, `kotonia-v4-flash`. Local: `gemma4-26b-uncensored`, `deepseek-v4-flash`. DeepSeek API: `deepseek-chat`, `deepseek-reasoner`."
        },
        "kotonia.approvalMode": {
          "type": "string",
          "enum": [
            "all",
            "allowlist",
            "auto"
          ],
          "default": "allowlist",
          "markdownDescription": "`all` gates every command, `allowlist` auto-runs read-only/build/test families and gates destructive ones, `auto` runs everything without asking."
        },
        "kotonia.workspaceMode": {
          "type": "string",
          "enum": [
            "worktree",
            "in-place"
          ],
          "default": "worktree",
          "markdownDescription": "`worktree` (default) runs the agent in an isolated git worktree so your working copy is untouched until you merge. `in-place` edits the workspace directly (edits show live in the editor, but no isolation)."
        },
        "kotonia.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra CLI arguments appended to the engine spawn (e.g. [\"--max-iterations\", \"50\"])."
        },
        "kotonia.language": {
          "type": "string",
          "default": "ja",
          "markdownDescription": "Default reply language for the agent (BCP-47-ish code, e.g. `ja`, `en`, `zh`). Injected as a one-line instruction on the first turn of each session; the agent still switches if you write in another language. Empty = no language steering."
        },
        "kotonia.avatar.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Show a talking lip-sync avatar (Ditto) that speaks each final answer, in its own movable/resizable panel. Streams from kotonia.ai `/api/voice/ditto/tts/stream/avatar` using your device login; needs the Ditto/TTS servers running."
        },
        "kotonia.avatar.character": {
          "type": "string",
          "default": "ことな",
          "markdownDescription": "Talking avatar **by name**. `ことな` (Kotona, AivisSpeech voice) or `ひなた` (Hinata, Irodori voice) resolve to the right avatar + voice automatically. Any other value is treated as a raw `avatar_id` (voice from `kotonia.avatar.ttsBackend` / `.speaker`). Use **Kotonia: アバターを選択** to pick."
        },
        "kotonia.avatar.persona": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Apply the selected character's personality (ことな / ひなた) to the agent's replies — it speaks in character while still using bash / tools. Injected once per session on the first turn. Turn off for a plain, neutral agent."
        },
        "kotonia.avatar.id": {
          "type": "string",
          "default": "kotona_v4",
          "markdownDescription": "Advanced: raw Ditto `avatar_id` used only when `kotonia.avatar.character` is not a known name. Normally set the character by name instead."
        },
        "kotonia.avatar.ttsBackend": {
          "type": "string",
          "enum": [
            "qwen3",
            "irodori",
            "voicevox",
            "aivis"
          ],
          "default": "aivis",
          "description": "TTS backend the avatar voice uses. The Kotona mascot uses AivisSpeech."
        },
        "kotonia.avatar.speaker": {
          "type": "string",
          "default": "888753762",
          "description": "Speaker/voice id passed to the TTS backend (backend-specific). Numeric ids (e.g. AivisSpeech まお-あまあま = 888753762) are sent as numbers. Empty = backend default."
        },
        "kotonia.avatar.speed": {
          "type": "number",
          "default": 1.2,
          "description": "Speech speed for the avatar voice (1.0 = normal)."
        },
        "kotonia.avatar.language": {
          "type": "string",
          "default": "ja",
          "description": "Language hint for the TTS backend (e.g. ja, en, zh)."
        },
        "kotonia.avatar.apiBase": {
          "type": "string",
          "default": "",
          "markdownDescription": "Override the API base for avatar streaming. Empty = use the server from your device login (`~/.kotonia/daemon.json`), falling back to `https://kotonia.ai`."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "package": "vsce package",
    "publish:marketplace": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
